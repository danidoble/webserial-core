# Algolia DocSearch credentials
# Leave empty to use the built-in local full-text search (default).
# Set all three to enable Algolia DocSearch — see https://docsearch.algolia.com/
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_INDEX_NAME=

# Algolia Admin (write) API key — used ONLY by `npm run docs:index`.
# This is the Admin API key from your Algolia dashboard.
# NEVER expose this key to the browser or commit it to version control.
ALGOLIA_WRITE_API_KEY=

# Full site origin used to build absolute URLs in Algolia records.
# e.g. https://danidoble.github.io  (no trailing slash, no path)
# Leave blank when hosting at root (/).
DOCS_URL=

# Base URL for the docs site.
# Leave empty for Netlify / Vercel (served at "/").
# Set to "/webserial-core/" for GitHub Pages (repo name).
# This is set automatically by the GitHub Actions workflow.
DOCS_BASE=
